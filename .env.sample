# ===============================
# 🔧 CORE SETTINGS
# ===============================

# Set environment: development / production
ENVIRONMENT=development

# Enable/Disable debug mode (True for dev, False for prod)
DEBUG=False
DJANGO_DEBUG=True

# Django secret key (generate securely for production)
SECRET_KEY=your-secret-key-here


# ===============================
# 🗄️ DATABASE CONFIGURATION
# ===============================

# Example (SQLite): sqlite:///db.sqlite3
DATABASE_URL=sqlite:///db.sqlite3

DB_NAME=education_website
DB_USER=root
DB_PASSWORD=your_secure_database_password


# ===============================
# 🌐 APPLICATION SETTINGS
# ===============================

APP_PORT=8000
DOMAIN_NAME=yourdomain.com

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=example.com,www.example.com,127.0.0.1,localhost

# CSRF trusted origins (include protocol)
CSRF_TRUSTED_ORIGINS=http://domain.com

# Custom admin URL (for security)
ADMIN_URL=a-dmin-url123


# ===============================
# 📧 EMAIL / NOTIFICATIONS
# ===============================

EMAIL_FROM=admin@example.com

# SendGrid configuration
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_PASSWORD=your-sendgrid-password

# Slack webhook for alerts
SLACK_WEBHOOK_URL=your-slack-webhook-url


# ===============================
# 🔐 SECURITY
# ===============================

# Encryption key (generate using: python web/master_key.py)
MESSAGE_ENCRYPTION_KEY=your-generated-key-here


# ===============================
# 💳 STRIPE CONFIGURATION
# ===============================

STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret


# ===============================
# ☁️ GOOGLE CLOUD STORAGE
# ===============================

GS_BUCKET_NAME=your-bucket-name
GS_PROJECT_ID=your-project-id
SERVICE_ACCOUNT_FILE=path/to/service-account.json


# ===============================
# 🐦 TWITTER API
# ===============================

TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET_KEY=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here


# ===============================
# 🚀 DEPLOYMENT SETTINGS
# ===============================

ENABLE_HTTPS_REDIRECT=True

PROJECT_NAME=education-website
PYTHON_VERSION=3.11

VPS_IP=your-vps-ip
VPS_USER=root
VPS_PASSWORD=your-vps-password

# Git repo for deployment
GIT_REPO=your_git_repo_to_deploy
GIT_BRANCH=your_repo_branch
